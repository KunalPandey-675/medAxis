{
  "name": "server",
  "type": "module",
  "private": true,
  "scripts": {
    "watch": "bun --watch server.ts",
    "start:ngrok": "cmd /c ngrok http 5000",
    "start:inngest": "npx inngest-cli@latest dev",
    "start:server": "nodemon --exec bun run src/server.ts",
    "dev": "concurrently -c \"blue,magenta,cyan\" -n \"SERVER,NGROK,INNGEST\" \"bun run start:server\" \"bun run start:ngrok\" \"npm run start:inngest\""
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/morgan": "^1.9.10",
    "@types/node": "^25.9.3",
    "concurrently": "^10.0.3",
    "nodemon": "^3.1.14"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@polar-sh/better-auth": "^1.8.4",
    "@polar-sh/sdk": "^0.48.1",
    "better-auth": "^1.6.22",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "groq-sdk": "^1.3.0",
    "helmet": "^8.2.0",
    "inngest": "^4.5.1",
    "mongodb": "^7.3.0",
    "mongoose": "^9.7.0",
    "morgan": "^1.11.0",
    "socket.io": "^4.8.3",
    "uploadthing": "^7.7.4"
  }
}